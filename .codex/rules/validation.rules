# generated by scaffold-guard; edit scaffold-guard.toml or rerun scaffold-guard compile-rules

prefix_rule(
    pattern = ["scaffold-guard", "check"],
    decision = "allow",
    justification = "Generated ScaffoldGuard policy checks are expected validation.",
    match = ["scaffold-guard check", "scaffold-guard check --path ."],
)

prefix_rule(
    pattern = ["scaffold-guard", "inspect-diff"],
    decision = "allow",
    justification = "Diff inspection is expected validation before claiming completion.",
    match = ["scaffold-guard inspect-diff", "scaffold-guard inspect-diff --path ."],
)

prefix_rule(
    pattern = ["scaffold-guard", "validate"],
    decision = "allow",
    justification = "Generated project validation is expected before claiming completion.",
    match = ["scaffold-guard validate", "scaffold-guard validate --quick"],
)

prefix_rule(
    pattern = ["uv", "run", "scaffold-guard", "check"],
    decision = "allow",
    justification = "Repository-local ScaffoldGuard checks are expected validation.",
    match = ["uv run scaffold-guard check"],
)



prefix_rule(
    pattern = ["uv", "run", "ruff", "format", "--check", "."],
    decision = "allow",
    justification = "Ruff format checks are expected read-only validation.",
    match = ["uv run ruff format --check ."],
)

prefix_rule(
    pattern = ["uv", "run", "ruff", "check", "."],
    decision = "allow",
    justification = "Ruff lint checks are expected validation.",
    match = ["uv run ruff check ."],
    not_match = ["uv run ruff check --fix ."],
)



prefix_rule(
    pattern = ["uv", "run", "mypy", "src"],
    decision = "allow",
    justification = "mypy checks are expected validation.",
    match = ["uv run mypy src tests examples"],
)



prefix_rule(
    pattern = ["uv", "run", "pyright"],
    decision = "allow",
    justification = "Pyright checks are expected validation.",
    match = ["uv run pyright"],
)


prefix_rule(
    pattern = ["uv", "run", "pytest", "tests"],
    decision = "allow",
    justification = "pytest commands under the generated test directory are expected validation.",
    match = ["uv run pytest tests"],
)


prefix_rule(
    pattern = ["uv", "run", "mkdocs", "build", "--strict"],
    decision = "allow",
    justification = "Strict MkDocs builds are expected documentation validation.",
    match = ["uv run mkdocs build --strict"],
)
